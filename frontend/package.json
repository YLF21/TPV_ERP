{
  "name": "tpv-erp-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:venta": "npm run dev --workspace @tpverp/app-venta",
    "dev:gestion": "npm run dev --workspace @tpverp/app-gestion",
    "app:venta": "node scripts/start-electron-app.mjs venta",
    "app:gestion": "node scripts/start-electron-app.mjs gestion",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run --exclude e2e/**",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.7.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "read-excel-file": "^9.2.0"
  }
}
